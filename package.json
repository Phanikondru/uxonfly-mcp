  },
  "license": "MIT",
  "homepage": "https://uxonfly.dev",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Phanikondru/uxonfly-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/Phanikondru/uxonfly-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.19.2",
